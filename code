/**
 * 统一 Product 排序逻辑
 *
 * 作用：
 * 1. 后台 Products 列表默认按 ACF order 升序
 * 2. 点击后台“排序 (Order)”列时，按 ACF order 升 / 降序
 * 3. 前端 product archive / product_category / 普通 category（含 product）按 ACF order 升序
 *
 * 说明：
 * - 有 order 的产品优先按数字从小到大
 * - 没有 order 的内容排在后面，再按发布时间倒序
 */
add_action( 'pre_get_posts', 'product_unified_sorting_logic', 99 );
function product_unified_sorting_logic( $query ) {
	if ( ! $query->is_main_query() ) {
		return;
	}
	// ----------------------------
	// 后台 Products 列表页
	// ----------------------------
	if ( is_admin() ) {
		global $pagenow, $typenow;
		if ( $pagenow !== 'edit.php' ) {
			return;
		}
		$current_post_type = $query->get( 'post_type' );
		if ( empty( $current_post_type ) && ! empty( $_GET['post_type'] ) ) {
			$current_post_type = sanitize_key( wp_unslash( $_GET['post_type'] ) );
		}
		if ( empty( $current_post_type ) && ! empty( $typenow ) ) {
			$current_post_type = $typenow;
		}
		if ( $current_post_type !== MY_PRODUCT_CPT ) {
			return;
		}
		$orderby = isset( $_GET['orderby'] ) ? sanitize_text_field( wp_unslash( $_GET['orderby'] ) ) : '';
		$order   = isset( $_GET['order'] ) ? strtoupper( sanitize_text_field( wp_unslash( $_GET['order'] ) ) ) : 'ASC';
		$order   = ( $order === 'DESC' ) ? 'DESC' : 'ASC';
		if ( $orderby !== '' && $orderby !== 'acf_order' ) {
			return;
		}
		$query->set(
			'meta_query',
			[
				'relation' => 'OR',
				[
					'key'     => MY_PRODUCT_ORDER_FIELD,
					'compare' => 'EXISTS',
				],
				[
					'key'     => MY_PRODUCT_ORDER_FIELD,
					'compare' => 'NOT EXISTS',
				],
			]
		);
		$query->set( 'meta_key', MY_PRODUCT_ORDER_FIELD );
		$query->set( 'meta_type', 'NUMERIC' );
		$query->set(
			'orderby',
			[
				'meta_value_num' => $order,
				'date'           => 'DESC',
				'title'          => 'ASC',
			]
		);
		return;
	}
	// ----------------------------
	// 前端 product 相关归档页
	// ----------------------------
	$is_product_archive = $query->is_post_type_archive( MY_PRODUCT_CPT );
	$is_product_tax     = $query->is_tax( [ 'product_category' ] );
	$is_normal_category = $query->is_category();
	if ( ! $is_product_archive && ! $is_product_tax && ! $is_normal_category ) {
		return;
	}
	$current_post_type = $query->get( 'post_type' );
	// 对普通分类页，前面已经把 post_type 扩展成 [post, product]
	// 对 product archive / product taxonomy，则直接排序
	if ( ! $is_normal_category ) {
		if ( is_array( $current_post_type ) ) {
			if ( ! in_array( MY_PRODUCT_CPT, $current_post_type, true ) ) {
				return;
			}
		} elseif ( $current_post_type && $current_post_type !== MY_PRODUCT_CPT ) {
			return;
		}
	}
	$query->set(
		'meta_query',
		[
			'relation' => 'OR',
			[
				'key'     => MY_PRODUCT_ORDER_FIELD,
				'compare' => 'EXISTS',
			],
			[
				'key'     => MY_PRODUCT_ORDER_FIELD,
				'compare' => 'NOT EXISTS',
			],
		]
	);
	$query->set( 'meta_key', MY_PRODUCT_ORDER_FIELD );
	$query->set( 'meta_type', 'NUMERIC' );
	$query->set(
		'orderby',
		[
			'meta_value_num' => 'ASC',
			'date'           => 'DESC',
			'title'          => 'ASC',
		]
	);
}
/**
 * 相关产品 shortcode
 * 用法：
 * [related_products_by_current_tax]
 */
add_shortcode('related_products_by_current_tax', function($atts) {
    if (!is_singular('product')) {
        return '<p>当前不是 product 页面</p>';
    }
    $atts = shortcode_atts([
        'limit' => 4,
    ], $atts);
    $current_post_id = get_queried_object_id();
    $term_ids = wp_get_post_terms($current_post_id, 'category', [
        'fields' => 'ids',
    ]);
    if (empty($term_ids)) {
        return '<p>当前产品没有分类（category）</p>';
    }
    $query = new WP_Query([
        'post_type'      => 'product',
        'posts_per_page' => intval($atts['limit']),
        'post__not_in'   => [$current_post_id],
        'tax_query' => [
            [
                'taxonomy' => 'category',
                'field'    => 'term_id',
                'terms'    => $term_ids,
            ],
        ],
        'meta_query' => [
            'relation' => 'OR',
            [
                'key'     => 'order',
                'compare' => 'EXISTS',
            ],
            [
                'key'     => 'order',
                'compare' => 'NOT EXISTS',
            ],
        ],
        'meta_key'  => 'order',
        'meta_type' => 'NUMERIC',
        'orderby'   => [
            'meta_value_num' => 'ASC',
            'date'           => 'DESC',
        ],
    ]);
    if (!$query->have_posts()) {
        return '<p>当前分类下没有其他产品</p>';
    }
    ob_start();
    ?>
    <div class="related-products-grid">
        <?php while ($query->have_posts()) : $query->the_post(); ?>
            <div class="related-product-item">
                <a href="<?php the_permalink(); ?>">
                    <?php the_post_thumbnail('medium'); ?>
                    <div><?php the_title(); ?></div>
                </a>
            </div>
        <?php endwhile; ?>
    </div>
    <?php
    wp_reset_postdata();
    return ob_get_clean();
});
