/**
 * Quick Edit：保存 Order 值
 */
add_action( 'save_post', 'product_save_quick_edit_order' );
function product_save_quick_edit_order( $post_id ) {
	if ( defined( 'DOING_AUTOSAVE' ) && DOING_AUTOSAVE ) {
		return;
	}
	if ( ! current_user_can( 'edit_post', $post_id ) ) {
		return;
	}
	if ( ! isset( $_POST['acf_order_value'] ) ) {
		return;
	}
	if ( get_post_type( $post_id ) !== MY_PRODUCT_CPT ) {
		return;
	}
	$order_value = intval( $_POST['acf_order_value'] );
	update_field( MY_PRODUCT_ORDER_FIELD, $order_value, $post_id );
}
